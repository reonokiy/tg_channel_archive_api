DATABASE_URL=postgres://tgarchive:tgarchive@localhost:5432/tgarchive?sslmode=disable
HTTP_ADDR=:8080
LOG_LEVEL=info

TELEGRAM_ENABLED=true

# Bot API mode receives new channel posts. Add the bot as a channel administrator.
TELEGRAM_SOURCE=bot
TELEGRAM_BOT_TOKEN=123456:replace-me
TELEGRAM_BOT_RECEIVE_MODE=longpoll
TELEGRAM_BOT_POLL_TIMEOUT=50s
TELEGRAM_BOT_SECRET_TOKEN=
TELEGRAM_BOT_WEBHOOK_PATH=/telegram/webhook
TELEGRAM_CHANNELS=some_public_channel,-1001234567890

# MTProto mode is optional and can be used for historical backfill/full reconciliation.
# TELEGRAM_SOURCE=mtproto
TELEGRAM_API_ID=123456
TELEGRAM_API_HASH=replace-me
TELEGRAM_PHONE=+15551234567
TELEGRAM_PASSWORD=
TELEGRAM_SESSION_FILE=telegram.session.json
TELEGRAM_POLL_INTERVAL=5m
TELEGRAM_BATCH_LIMIT=100

RATE_LIMIT_RPS=2
RATE_LIMIT_BURST=10
CORS_ORIGIN=*
DEFAULT_PAGE_LIMIT=50
MAX_PAGE_LIMIT=100
TRUST_PROXY_HEADERS=false
